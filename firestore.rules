rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Public read for doctor/lab search on landing page
      allow read: if true;
      // Only the user themselves can write their own profile
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Medical Records ────────────────────────────────────────────────────
    match /medical_records/{recordId} {
      // Patient can read their own records
      // Doctor can read if they have access permission OR universal access is on
      allow read: if request.auth != null && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid ||
        isAuthorizedForPatient(resource.data.patientId)
      );
      // Only doctors and hospitals can create
      allow create: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['doctor', 'hospital']
      );
      // Only the creating doctor can update/delete
      allow update, delete: if request.auth != null && resource.data.doctorId == request.auth.uid;
    }

    // ── Lab Results ────────────────────────────────────────────────────────
    match /lab_results/{resultId} {
      allow read: if request.auth != null && (
        resource.data.patientId == request.auth.uid ||
        resource.data.labId == request.auth.uid ||
        isAuthorizedForPatient(resource.data.patientId)
      );
      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'lab';
      allow update, delete: if request.auth != null && resource.data.labId == request.auth.uid;
    }

    // ── Appointments ───────────────────────────────────────────────────────
    match /appointments/{apptId} {
      allow read: if request.auth != null && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid
      );
      allow delete: if request.auth != null && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid
      );
    }

    // ── Access Permissions ─────────────────────────────────────────────────
    match /access_permissions/{permId} {
      allow read: if request.auth != null && (
        resource.data.patientId == request.auth.uid ||
        resource.data.granteeId == request.auth.uid
      );
      allow create, update: if request.auth != null &&
        request.resource.data.patientId == request.auth.uid;
      allow delete: if request.auth != null &&
        resource.data.patientId == request.auth.uid;
    }

    // ── Hospital Admissions ────────────────────────────────────────────────
    match /hospital_admissions/{admId} {
      allow read, write: if request.auth != null && (
        resource.data.patientId == request.auth.uid ||
        resource.data.hospitalId == request.auth.uid
      );
      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'hospital';
    }

    // ── Patient Health Profile Collections ────────────────────────────────
    match /patient_allergies/{docId} {
      allow read: if request.auth != null && (
        resource.data.patientId == request.auth.uid ||
        isAuthorizedForPatient(resource.data.patientId)
      );
      allow create: if request.auth != null && request.resource.data.patientId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.patientId == request.auth.uid;
    }
    match /patient_medications/{docId} {
      allow read: if request.auth != null && (
        resource.data.patientId == request.auth.uid ||
        isAuthorizedForPatient(resource.data.patientId)
      );
      allow create: if request.auth != null && request.resource.data.patientId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.patientId == request.auth.uid;
    }
    match /patient_family_history/{docId} {
      allow read: if request.auth != null && (
        resource.data.patientId == request.auth.uid ||
        isAuthorizedForPatient(resource.data.patientId)
      );
      allow create: if request.auth != null && request.resource.data.patientId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.patientId == request.auth.uid;
    }
    match /patient_side_effects/{docId} {
      allow read: if request.auth != null && (
        resource.data.patientId == request.auth.uid ||
        isAuthorizedForPatient(resource.data.patientId)
      );
      allow create: if request.auth != null && request.resource.data.patientId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.patientId == request.auth.uid;
    }
    match /patient_vitals/{docId} {
      allow read: if request.auth != null && (
        resource.data.patientId == request.auth.uid ||
        isAuthorizedForPatient(resource.data.patientId)
      );
      allow create: if request.auth != null && request.resource.data.patientId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.patientId == request.auth.uid;
    }
    match /patient_documents/{docId} {
      allow read: if request.auth != null && (
        resource.data.patientId == request.auth.uid ||
        isAuthorizedForPatient(resource.data.patientId)
      );
      allow create: if request.auth != null && request.resource.data.patientId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.patientId == request.auth.uid;
    }

    // ── Notifications ──────────────────────────────────────────────────────
    match /notifications/{userId}/items/{notifId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // ── Access Requests ────────────────────────────────────────────────────
    match /access_requests/{reqId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && (
        resource.data.doctorId == request.auth.uid ||
        resource.data.patientId == request.auth.uid
      );
    }

    // ── Doctor Medication Lists ────────────────────────────────────────────
    match /doctor_med_lists/{doctorId} {
      allow read, write: if request.auth != null && request.auth.uid == doctorId;
    }

    // ── QR Access Tokens ──────────────────────────────────────────────────
    match /qr_access_tokens/{tokenId} {
      allow create: if request.auth != null && request.resource.data.patientId == request.auth.uid;
      allow read: if true;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && resource.data.patientId == request.auth.uid;
    }

    // ── Treatment Plans ────────────────────────────────────────────────────
    match /treatment_plans/{planId} {
      allow read: if request.auth != null && (
        resource.data.patientId == request.auth.uid ||
        resource.data.doctorId == request.auth.uid
      );
      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor';
      allow delete: if request.auth != null && resource.data.doctorId == request.auth.uid;
    }

    // ── Helper function ────────────────────────────────────────────────────
    function isAuthorizedForPatient(patientId) {
      return (
        get(/databases/$(database)/documents/users/$(patientId)).data.universalDoctorAccess == true &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor'
      ) || exists(/databases/$(database)/documents/access_permissions/$(patientId + '_' + request.auth.uid));
    }
  }
}
